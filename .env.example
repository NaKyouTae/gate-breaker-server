DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gatebreaker
REDIS_URL=redis://localhost:6379
JWT_SECRET=your-secret-key
JWT_REFRESH_SECRET=your-refresh-secret
KAKAO_CLIENT_ID=your-kakao-client-id
KAKAO_CLIENT_SECRET=your-kakao-client-secret
KAKAO_ADMIN_KEY=your-kakao-admin-key
KAKAO_REDIRECT_URI=http://localhost:4000/auth/kakao/callback
FRONTEND_URL=http://localhost:3000

# Supabase Storage (option A: Supabase JS)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
SUPABASE_BUCKET=gate-breaker

# Supabase Storage (option B: S3-compatible)
SUPABASE_ACCESS_KEY=your-s3-access-key
SUPABASE_SECRET_KEY=your-s3-secret-key
SUPABASE_S3_ENDPOINT=https://your-project-ref.supabase.co/storage/v1/s3
SUPABASE_S3_REGION=us-east-1
SUPABASE_PUBLIC_BASE_URL=https://your-project-ref.supabase.co
